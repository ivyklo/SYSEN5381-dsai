import time
from datetime import datetime, timedelta

BASE_URL = "https://api.pugetsound.onebusaway.org/api/where"
# Fixed stop for this team project:
# "U District Station - Bay 3" (stop id 1_10911 in the Puget Sound feed)
STOP_ID = "1_10911"

def get_delay_samples_for_time(dt):
    """
    Query OneBusAway for a 60-minute window around a given time `dt`
    at U District Station Bay 3, and compute the delay between
    scheduled and predicted arrival times for each trip that has
    real-time prediction data.
    """
    epoch_ms = int(dt.timestamp() * 1000)
    url = f"{BASE_URL}/arrivals-and-departures-for-stop/{STOP_ID}.json"
    params = {
        "key": ONEBUSAWAY_API_KEY,
        "time": epoch_ms,
        "minutesBefore": 0,
        "minutesAfter": 60,
    }
    resp = requests.get(url, params=params)
    print("Status code for", dt, ":", resp.status_code)
    # Show a bit of the body if something goes wrong
    if resp.status_code != 200:
        print("Response preview:", resp.text[:200])
    resp.raise_for_status()
    data = resp.json()["data"]["entry"]["arrivalsAndDepartures"]

    delays = []
    for ad in data:
        sched = ad.get("scheduledArrivalTime")
        pred = ad.get("predictedArrivalTime")
        # Skip if we don't have a schedule or a valid prediction
        # Some responses use 0/negative for "no prediction", which maps to 1969-12-31.
        if sched is None or pred is None or pred <= 0:
            continue
        delay_min = (pred - sched) / 60000.0
        delays.append({
            "routeId": ad.get("routeId"),
            "tripId": ad.get("tripId"),
            "scheduledArrival_ms": sched,
            "predictedArrival_ms": pred,
            "delay_min": delay_min,
            "query_time": dt,
        })
    return delays

# Query window for this analysis:
# sample once per hour over a 24-hour period on 2026-03-01
start = datetime(2026, 3, 1, 0, 0)
end = datetime(2026, 3, 2, 0, 0)  # exclusive upper bound (covers up to 2026-03-01 23:59)
step = timedelta(hours=1)

all_samples = []
# Loop over each hour in the date range and accumulate delay records
t = start
while t < end:
    all_samples.extend(get_delay_samples_for_time(t))
    t += step

print(f"Collected {len(all_samples)} arrival samples "
      f"between {start} and {end} (hourly queries).")

# Save all samples to JSON file in Team_Project folder for later analysis
output_path = os.path.join(
    os.path.dirname(__file__),
    "team_project_query_result.json"
)
with open(output_path, "w", encoding="utf-8") as f:
    json.dump(all_samples, f, default=str, indent=2)
print(f"Saved results to {output_path}")

# Print the first 20 samples (avoid huge output)
for s in all_samples[:20]:
    sched_dt = datetime.fromtimestamp(s["scheduledArrival_ms"] / 1000.0)
    pred_dt = datetime.fromtimestamp(s["predictedArrival_ms"] / 1000.0)
    print(
        f"Route {s['routeId']} | Trip {s['tripId']} | "
        f"Scheduled: {sched_dt} | Predicted: {pred_dt} | "
        f"Delay: {s['delay_min']:.2f} minutes"
    )